# Maintainer: Sean Gillespie <sean@mistersg.net>
pkgname=cardano-node-bin
pkgver=11.0.1
pkgrel=1
pkgdesc="The core component that is used to participate in a Cardano decentralised blockchain."
arch=("x86_64")
url="https://github.com/input-output-hk/cardano-node"
license=('Apache-2.0')
depends=('cardano-conf')
provides=("cardano-node")
conflicts=("cardano-node" "cardano-node-git")
backup=()
options=(!debug !strip)

# Configuration files from cardano-playground repository (pinned commit)
# Commit: e18bf6327fa9956c907739d049e9b3ec0c6a7dd6
_config_commit=e18bf6327fa9956c907739d049e9b3ec0c6a7dd6

source=(
  "cardano-node.service"
  "cardano-node.sysusers"
  "https://github.com/IntersectMBO/cardano-node/releases/download/$pkgver/cardano-node-$pkgver-linux-amd64.tar.gz"
)
sha256sums=('5b50c626a3bc154f80b6b405d10a2b26de614f482db712868d65cc36a6b76616'
            '245d223f503346bb96e3541ce06795aabbc94e01f36925b449e113be382f6fbe'
            '40e88a543564251338c4888ef79fde51d2306c18b48ac308c9eab3220e3a13f0')

check() {
  "${srcdir}/bin/cardano-node" version | grep -q "$pkgver"
  "${srcdir}/bin/cardano-cli" version
}

package() {
  install -d "${pkgdir}/usr/bin"
  install -d "${pkgdir}/etc/cardano/"{mainnet,preprod,preview}

  # systemd unit files
  install -D -m0644 "${srcdir}/cardano-node.service" "${pkgdir}/usr/lib/systemd/system/cardano-node.service"
  install -D -m0644 "${srcdir}/cardano-node.sysusers" "${pkgdir}/usr/lib/sysusers.d/cardano-node.conf"

  # static binaries
  install -D -m0755 "${srcdir}/bin/"{cardano-cli,cardano-node} "${pkgdir}/usr/bin"
}
